generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlantDifficulty {
  VERY_EASY
  EASY
  MEDIUM
  HARD
}

enum UserPlantStatus {
  PLANNED
  SOWED
  GROWING
  WAITING_FOR_SPROUTS
  SPROUTED
  HARVESTING
  FINISHED
  ARCHIVED
}

enum PlantStageKey {
  SOWING
  WAITING_FOR_SPROUTS
  FIRST_LEAVES
  GROWTH
  PINCHING
  HARVEST
  CUSTOM
}

enum Place {
  WINDOWSILL
  BALCONY
  GROW_LIGHT_SHELF
  UNKNOWN
}

enum LightCondition {
  FULL_DAY
  FEW_HOURS
  LOW_LIGHT
  UNKNOWN
}

enum ContainerType {
  SMALL_POT
  LONG_BOX
  CONTAINER
  NOT_READY
}

enum TaskType {
  WATER_CHECK
  VENTILATE
  LIGHT
  THINNING
  PINCHING
  HARVEST
  NOTE
  OTHER
}

enum CareMode {
  SIMPLE
  EXPERT
}

enum NotificationType {
  TASK_DUE
  WEATHER_WARNING
  PLANT_STAGE
  SYSTEM
}

enum SubscriptionPlan {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  NONE
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          UserRole       @default(USER)
  city          String?
  country       String?
  latitude      Float?
  longitude     Float?
  careMode      CareMode       @default(SIMPLE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  plants        UserPlant[]
  aiUsageLogs   AiUsageLog[]
  notifications Notification[]
  subscription  Subscription?

  @@index([email])
  @@index([role])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(NONE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  dedupeKey String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model PlantCatalog {
  id                     String          @id @default(cuid())
  name                   String          @unique
  type                   String
  difficulty             PlantDifficulty @default(EASY)
  description            String
  lightRequirement       String
  waterRequirement       String
  averageGerminationDays Int
  averageHarvestDays     Int
  recommendedContainer   String
  sowingDepth            String?
  temperature            String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  userPlants             UserPlant[]
  stages                 PlantStage[]

  @@index([type])
  @@index([difficulty])
}

model UserPlant {
  id             String            @id @default(cuid())
  userId         String
  plantCatalogId String
  customName     String?
  status         UserPlantStatus   @default(WAITING_FOR_SPROUTS)
  plantedAt      DateTime          @default(now())
  currentStage   PlantStageKey     @default(SOWING)
  place          Place             @default(UNKNOWN)
  lightCondition LightCondition    @default(UNKNOWN)
  containerType  ContainerType     @default(NOT_READY)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plantCatalog   PlantCatalog      @relation(fields: [plantCatalogId], references: [id], onDelete: Restrict)
  careTasks      CareTask[]
  diaryEntries   PlantDiaryEntry[]

  @@index([userId])
  @@index([plantCatalogId])
  @@index([status])
  @@index([plantedAt])
}

model CareTask {
  id          String    @id @default(cuid())
  userPlantId String
  title       String
  description String
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  taskType    TaskType  @default(OTHER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userPlant   UserPlant @relation(fields: [userPlantId], references: [id], onDelete: Cascade)

  @@index([userPlantId])
  @@index([dueDate])
  @@index([isCompleted])
  @@index([taskType])
}

model PlantStage {
  id             String        @id @default(cuid())
  plantCatalogId String
  title          String
  description    String
  stageKey       PlantStageKey @default(CUSTOM)
  dayFrom        Int
  dayTo          Int
  order          Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  plantCatalog   PlantCatalog  @relation(fields: [plantCatalogId], references: [id], onDelete: Cascade)

  @@unique([plantCatalogId, order])
  @@index([plantCatalogId])
  @@index([stageKey])
}

model PlantDiaryEntry {
  id          String    @id @default(cuid())
  userPlantId String
  note        String
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userPlant   UserPlant @relation(fields: [userPlantId], references: [id], onDelete: Cascade)

  @@index([userPlantId])
  @@index([createdAt])
}
